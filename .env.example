# =============================================================================
# Voowork Desktop — Environment Configuration
# =============================================================================
#
# Copy this file to `.env` for development:
#   cp .env.example .env
#
# IMPORTANTE: O valor de API_URL é COMPILADO no binário em TODOS os builds
# (dev e release). O build.rs lê este .env e injeta o valor via
# `cargo:rustc-env`. Portanto:
#
#   • Edite API_URL neste arquivo para controlar para onde o app aponta
#   • `npm run tauri dev` — usa o valor do .env (lido pelo build.rs)
#   • `npm run tauri build` — usa o valor do .env (lido pelo build.rs)
#   • NÃO precisa de comandos especiais — apenas npm run tauri build
#
# =============================================================================

# --- App version (Vite: displayed in footer) ---
VITE_APP_VERSION=0.1.0

# --- API Base URL (Rust: ALL backend communication) ---
# Development — Rails local (voowork-backend on port 3000)
API_URL=http://localhost:3000

# Production
# API_URL=https://api.voowork.com

# --- Web dashboard URL (Vite: link "Open web panel") ---
# Development — SPA local (voowork-frontend)
VITE_WEB_URL=http://localhost:5173

# Production
# VITE_WEB_URL=https://app.voowork.com

# --- S3 / Garage (Rust: direct screenshot upload) ---
# Development — same Garage instance as backend
S3_ENDPOINT=https://s3.alessandrosales.com.br
S3_REGION=garage
S3_ACCESS_KEY=GK5cd00b7d3019a5cabbb25676
S3_SECRET_KEY=1a5ca49d5500eb7e61b6d0a14a7d8b6cad6ab651aef1877970b016959941f597
S3_BUCKET=voowork-dev

# Production
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=garage
# S3_ACCESS_KEY=CHANGE_ME
# S3_SECRET_KEY=CHANGE_ME
# S3_BUCKET=voowork-production

# --- Screenshot interval override (dev only) ---
# Minimum 10s. Restart app after changing.
# SCREENSHOT_INTERVAL_SECS=60
