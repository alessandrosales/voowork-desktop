# Overrides do agente desktop (carregado após voowork-backend/.env).
#
# Setup:
#   cp ../voowork-backend/.env.example ../voowork-backend/.env
#   cp .env.example .env
#
# Variáveis no backend (.env compartilhada):
#   VITE_API_URL   — API Rails (auth, sync, projetos)
#   FRONTEND_URL   — painel web (link "Abrir painel web")
#
# Variáveis do agente desktop (este arquivo):
VITE_APP_VERSION=0.1.0

# S3 / Garage — upload direto de screenshots (subir com `bin/dev-infra` no backend)
S3_ENDPOINT=http://127.0.0.1:3900
S3_REGION=garage
S3_ACCESS_KEY=voowork-dev-access-key
S3_SECRET_KEY=voowork-dev-secret-key-change-me
S3_BUCKET=voowork-dev

# SCREENSHOT_INTERVAL_SECS=60
