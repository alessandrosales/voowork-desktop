# =============================================================================
# Voowork Desktop — Environment Configuration
# =============================================================================
#
# Copy this file to `.env` for development:
#   cp .env.example .env
#
# IMPORTANTE: VITE_API_URL e FRONTEND_URL são COMPILADAS no binário. O build.rs
# lê este .env e injeta os valores via `cargo:rustc-env`. Portanto:
#
#   • Edite VITE_API_URL para controlar para onde o app aponta
#   • `npm run tauri dev` / `npm run tauri build` — usam o valor do .env
#   • RELEASE (`npm run tauri build`) FALHA se VITE_API_URL não estiver definida
#     (fail-loud) — evita builds de produção apontando para localhost
#
# =============================================================================

# --- App version (Vite: displayed in footer) ---
VITE_APP_VERSION=0.1.0

# --- API Base URL (Rust: ALL backend communication) ---
# Obrigatória em release. Aceita o nome legado API_URL por compatibilidade.
# Development — Rails local (voowork-backend on port 3000)
VITE_API_URL=http://localhost:3000

# Production
# VITE_API_URL=https://api.voowork.com

# --- Web dashboard URL (Rust: link "Open web panel") ---
# Lida por navigation::configured_web_panel_url. Aceita o legado VITE_WEB_URL.
# Development — SPA local (voowork-frontend)
FRONTEND_URL=http://localhost:5173

# Production
# FRONTEND_URL=https://app.voowork.com

# --- S3 / Garage (Rust: direct screenshot upload) ---
# Development — same Garage instance as backend
S3_ENDPOINT=https://s3.voowork.com
S3_REGION=garage
S3_ACCESS_KEY=chave-aqui-s3
S3_SECRET_KEY=chave-aqui-s3
S3_BUCKET=voowork-dev

# Production
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=garage
# S3_ACCESS_KEY=CHANGE_ME
# S3_SECRET_KEY=CHANGE_ME
# S3_BUCKET=voowork-production

# --- Screenshot interval override (dev only) ---
# Minimum 10s. Restart app after changing.
# SCREENSHOT_INTERVAL_SECS=60

# --- MCP Postgres full-access (OpenCode/Cursor agents only) ---
# Usado por opencode.jsonc via {env:VAR}. NUNCA colocar connection string
# literal no opencode.jsonc — sempre referenciar esta variável.
VOOWORK_MCP_PG_WRITE_URL=postgresql://postgres:postgres@localhost:5434/voowork_db
