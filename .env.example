# Copy for local development:
#   cp .env.example .env
#
# Production: copy to `.env.production` before `bun run tauri build`,
# or set the same variables in the OS environment on the target machine.

# --- App (Vite: versão exibida no rodapé) ---
VITE_APP_VERSION=0.1.0

# --- API (Rust: auth, sync, projetos) ---
# Development — Rails local (voowork-backend)
VOOWORK_API_URL=http://localhost:3000

# Production
# VOOWORK_API_URL=https://api.voowork.com

# --- Web dashboard (Vite: link "Abrir painel web" | Rust: open_web_panel) ---
# Development — SPA local (voowork-frontend)
VITE_VOOWORK_WEB_URL=http://localhost:5173
# Rust também lê VOOWORK_WEB_PANEL_URL (opcional, sobrescreve VITE_*)
# VOOWORK_WEB_PANEL_URL=http://localhost:5173

# Production
# VITE_VOOWORK_WEB_URL=https://app.voowork.com

# --- S3 / Garage (Rust: upload direto de screenshots) ---
# Dev: suba o Garage com voowork-backend (`bin/dev-infra` ou docker-compose.dev-infra.yml)
VOOWORK_S3_ENDPOINT=http://127.0.0.1:3900
VOOWORK_S3_REGION=garage
VOOWORK_S3_ACCESS_KEY=voowork-dev-access-key
VOOWORK_S3_SECRET_KEY=voowork-dev-secret-key-change-me
VOOWORK_S3_BUCKET=voowork-dev

# Production
# VOOWORK_S3_ENDPOINT=https://s3.example.com
# VOOWORK_S3_REGION=garage
# VOOWORK_S3_ACCESS_KEY=CHANGE_ME
# VOOWORK_S3_SECRET_KEY=CHANGE_ME
# VOOWORK_S3_BUCKET=voowork-production

# --- Screenshot interval (dev only) ---
# Intervalo base entre capturas durante tracking (mínimo 10s).
# Tem prioridade sobre o valor em SQLite — use para testar intervalos sem alterar backend.
# Reinicie o app após alterar.
# VOOWORK_SCREENSHOT_INTERVAL_SECS=60
