# Copy for local development:
#   cp .env.example .env
#
# Production: copy to `.env.production` before `bun run tauri build`,
# or set the same variables in the OS environment on the target machine.

# --- App (Vite: versão exibida no rodapé) ---
VITE_APP_VERSION=0.1.0

# --- API (Rust: auth, sync, projetos) ---
# Development — Rails local (voowork-backend)
VOOWORK_API_URL=http://localhost:3000

# Production
# VOOWORK_API_URL=https://api.voowork.com

# --- Web dashboard (Vite: link "Abrir painel web") ---
# Development — SPA local (voowork-frontend)
VITE_VOOWORK_WEB_URL=http://localhost:5173

# Production
# VITE_VOOWORK_WEB_URL=https://app.voowork.com

# --- Optional (dev only) ---
# Minimum 10 seconds. Overrides screenshot interval for faster local testing.
# VOOWORK_SCREENSHOT_INTERVAL_SECS=60
