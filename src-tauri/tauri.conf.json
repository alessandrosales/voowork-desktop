{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voowork",
  "mainBinaryName": "voowork-desktop",
  "version": "0.1.0",
  "identifier": "com.voowork.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Voowork",
        "width": 480,
        "height": 700,
        "minWidth": 400,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": true
      },
      {
        "label": "mini-timer",
        "title": "Voowork",
        "url": "index.html?view=mini",
        "width": 200,
        "height": 20,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "dragDropEnabled": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' tauri: ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; font-src 'self' data:; connect-src 'self' tauri: ipc: http://ipc.localhost https://api.voowork.com http://localhost:3000 http://127.0.0.1:3000 http://localhost:1420 ws://localhost:1420 ws://127.0.0.1:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "minimumSystemVersion": "13.0"
    }
  }
}
