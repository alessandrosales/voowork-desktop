{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voowork",
  "mainBinaryName": "voowork-desktop",
  "version": "0.1.0",
  "identifier": "com.voowork.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Voowork",
        "width": 480,
        "height": 700,
        "minWidth": 400,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
