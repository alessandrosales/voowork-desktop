{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "desktop-agent-orchestrator",

  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",

    "webfetch": "ask",
    "websearch": "ask",

    "bash": {
      "*": "allow",

      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "rg *": "allow",

      "npm *": "allow",
      "npx *": "allow",
      "cargo *": "allow",

      "git *": "allow",
      "git commit *": "ask",
      "git push *": "deny",
      "rm *": "deny",
      "sudo *": "deny"
    }
  },

  "instructions": [
    "AGENTS.md",
    ".opencode/rules/local-config-isolation.md",
    ".opencode/rules/backend-boundary.md",
    ".opencode/rules/tauri-dev-cli.md",
    ".opencode/rules/sqlite-local-schema.md"
  ],

  "agent": {
    "desktop-agent-orchestrator": {
      "description": "Orquestrador multi-agente do voowork-desktop. Coordena subagentes, preserva contexto e valida entrega via desktop-implementation-auditor.",
      "mode": "primary",
      "prompt": "{file:.opencode/agents/desktop-agent-orchestrator.md}"
    },
    "desktop-implementation-planner": {
      "description": "Planejamento técnico read-only. Analisa o codebase Tauri/Rust/React e produz plano de execução antes de codar.",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/desktop-implementation-planner.md}",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "desktop-implementation-auditor": {
      "description": "Auditoria read-only. Valida implementação contra demanda, plano e restrições do projeto. Retorna PASS/FAIL.",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/desktop-implementation-auditor.md}",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "desktop-rust-specialist": {
      "description": "Especialista Rust/Tauri core. Módulos em src-tauri: tracking, sync, db, activity, screenshot, idle, auth, commands.",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/desktop-rust-specialist.md}"
    },
    "desktop-react-ui-specialist": {
      "description": "Especialista React/TypeScript UI. Componentes timer, hooks, i18n, integração via invoke Tauri.",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/desktop-react-ui-specialist.md}"
    },
    "desktop-verification-specialist": {
      "description": "Verificação e validação. cargo check/clippy, bun typecheck, smoke manual do agente desktop.",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/desktop-verification-specialist.md}"
    },
    "desktop-implementation-specialist": {
      "description": "Roteador de implementação quando o escopo cruza Rust + React ou está ambíguo.",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/desktop-implementation-specialist.md}"
    }
  },

  "skills": {
    "paths": [".opencode/skills", ".agents/skills"]
  },

  "mcp": {
    "voowork_production_pg_write": {
      "type": "local",
      "command": ["npx", "-y", "mcp-postgres-full-access", "postgresql://postgres:postgres@localhost:5434/voowork_db"],
      "enabled": true,
      "env": {
        "TRANSACTION_TIMEOUT_MS": "60000",
        "PG_STATEMENT_TIMEOUT_MS": "30000",
        "MAX_CONCURRENT_TRANSACTIONS": "3"
      }
    }
  }
}
